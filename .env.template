# JEPA-WMs environment variables
# Copy this file to .env and fill in your local paths.
# The .env file is gitignored and loaded automatically by expand_env_vars().

# Root directory for training and eval logs/outputs
JEPAWM_LOGS=/path/to/your/logs

# Root directory for datasets (PushT, MetaWorld, etc.)
JEPAWM_DSET=/path/to/your/datasets

# Root directory for model checkpoints
JEPAWM_CKPT=/path/to/your/checkpoints

# Root directory for open-source pretrained encoder checkpoints (V-JEPA, DINOv2)
JEPAWM_OSSCKPT=/path/to/opensource/checkpoints
